# ============================================================
# Multi-Agent Platform - Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# --- Application ---
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-secret
LOG_LEVEL=INFO

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=multiagent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# --- Qdrant (Vector DB) ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=agent_memory

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- LLM Provider ---
# Options: openai | ollama | local
LLM_PROVIDER=openai
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.1:8b
LLM_API_KEY=ollama

# --- Embedding Model ---
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768

# --- Tool - Web Search ---
SEARCH_ENGINE=duckduckgo
SERPER_API_KEY=

# --- Docker Sandbox ---
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MEMORY_LIMIT=256m

# --- HITL ---
HITL_CONFIDENCE_THRESHOLD=0.75

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8065
NEXT_PUBLIC_WS_URL=ws://localhost:8065
